# Telegram
TELEGRAM_BOT_TOKEN=your_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id

# LinkedIn
LINKEDIN_COOKIES_PATH=./data/cookies/linkedin.json

# Database
DB_PATH=./data/jobs.db

# Scheduling
CRON_MORNING=0 9 * * *
CRON_EVENING=0 18 * * *

# Scoring
SCORE_HIGH=65
SCORE_MAYBE=45

# Scraping
MAX_DETAIL_FETCHES=30
MAX_RUN_DURATION_MS=1200000
LINKEDIN_POSTED_WITHIN=r86400

# Deduplication
DEDUP_WINDOW_DAYS=14

# Development
DRY_RUN=false
HEADED=false
LOG_LEVEL=info

# V2 (leave empty in V1)
OPENAI_API_KEY=
LLM_MODEL=gpt-5-nano
